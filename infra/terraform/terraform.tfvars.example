# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored — never commit it

region        = "us-east-1"
ami_id        = "ami-0c02fb55956c7d316"  # Ubuntu 22.04 us-east-1 — update for your region
instance_type = "t3.micro"
key_name      = "MyAppKeyPair.pem"
your_ip       = "203.0.113.10/32"        # your PUBLIC IPv4: curl -4 ifconfig.me  (use -4 to force IPv4)
